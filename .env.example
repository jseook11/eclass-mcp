# 개발용 .env (scripts/discover.ts 전용). 복사: cp .env.example .env
# 프로덕션 MCP 서버는 이 파일을 읽지 않으며 키체인을 사용한다. .env는 gitignore됨.
#
# 비밀번호를 평문으로 두는 임시 개발 설정이다. 디스커버리 작업이 끝나면
# .env를 삭제하고 비밀번호를 변경할 것.

ECLASS_USERNAME=your-id
ECLASS_PASSWORD=your-temp-password

# 위 ECLASS_PASSWORD(평문 env)를 실제로 사용하려면 반드시 1로 켜야 한다.
# 켜지 않으면 env 비밀번호는 무시되고 키체인을 조회한다.
ALLOW_PLAINTEXT_ENV_SECRETS=1

# 선택: 네트워크 캡처 디버그 로그
# DEBUG=1

# 선택: ChatGPT/Responses API remote MCP 개발 서버
# ECLASS_TRANSPORT=http
# ECLASS_HTTP_PORT=8787
# ECLASS_REMOTE_AUTH_TOKEN=change-me-long-random-token
# ECLASS_HTTP_ALLOWED_ORIGINS=https://chatgpt.com,https://chat.openai.com
