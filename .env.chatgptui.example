# chatgptui(ChatGPT Secure MCP Tunnel) 런타임 env. 복사해서 채운다:
#   cp .env.chatgptui.example .env.chatgptui
#
# 채운 뒤에는 매번 export 할 필요 없이 `npm run chatgptui`만 실행하면 된다.
# scripts/chatgptui.ts가 시작 시 이 파일을 자동 로드한다(.env.chatgptui).
# 이미 셸에 export된 변수가 있으면 그 값이 우선한다. 파일은 gitignore된다.
#
# 다른 경로를 쓰려면: ECLASS_CHATGPTUI_ENV_FILE=/path/to.env npm run chatgptui

# Platform Tunnels에서 발급한 런타임 API 키와 tunnel id
CONTROL_PLANE_API_KEY=sk-...
CONTROL_PLANE_TUNNEL_ID=tunnel_...

# 선택: eclass 로그인 아이디. 비워두면 `pnpm run setup`이 저장한
# Hermes/.mcp.json 설정에서 자동으로 찾는다.
# ECLASS_USERNAME=your_id

# 선택(헤드리스/server용): 암호화 자격증명 백엔드
# pnpm run setup -- --target encrypted 로 구성한 경우에만 주입한다.
# ECLASS_CREDENTIAL_BACKEND=encrypted
# ECLASS_SECRET_KEY=base64-32바이트-마스터-키

# 선택: 장기 고정 인증 토큰. 미설정이면 매 실행마다 랜덤 토큰을 생성한다.
# ECLASS_REMOTE_AUTH_TOKEN=change-me-long-random-token
